{
  "name": "google/gemma-3-4b-it",
  "match_substrings": [
    "google/gemma-3-4b-it",
    "gemma-3-4b-it",
    "gemma-3"
  ],
  "vllm": {
    "enforce_eager": false,
    "max_new_tokens": 1024,
    "max_model_len": 4096,
    "max_num_batched_tokens": 4096,
    "max_num_seqs": 8,
    "gpu_memory_utilization": 0.90,
    "tensor_parallel_size": 1,
    "swap_space": 8.0,
    "cpu_offload_gb": 0.0
  },
  "quantization": {
    "awq": {
      "ignore": [
        "language_model.lm_head",
        "re:.*vision_tower\\..*",
        "re:.*multi_modal_projector\\..*"
      ],
      "mappings": [
        {
          "smooth_layer": "re:^model\\.language_model\\.layers\\.[0-9]+\\.input_layernorm$",
          "balance_layers": [
            "re:^model\\.language_model\\.layers\\.[0-9]+\\.self_attn\\.q_proj$",
            "re:^model\\.language_model\\.layers\\.[0-9]+\\.self_attn\\.k_proj$",
            "re:^model\\.language_model\\.layers\\.[0-9]+\\.self_attn\\.v_proj$"
          ]
        },
        {
          "smooth_layer": "re:^model\\.language_model\\.layers\\.[0-9]+\\.pre_feedforward_layernorm$",
          "balance_layers": [
            "re:^model\\.language_model\\.layers\\.[0-9]+\\.mlp\\.gate_proj$",
            "re:^model\\.language_model\\.layers\\.[0-9]+\\.mlp\\.up_proj$"
          ]
        },
        {
          "smooth_layer": "re:^model\\.language_model\\.layers\\.[0-9]+\\.mlp\\.up_proj$",
          "balance_layers": [
            "re:^model\\.language_model\\.layers\\.[0-9]+\\.mlp\\.down_proj$"
          ]
        }
      ]
    }
  },
  "env": {
    "PYTORCH_CUDA_ALLOC_CONF": "expandable_segments:True"
  },
  "prompt": {
    "add_target_lang_prompt": false,
    "model_instruction": "Provide only one translation and do not output anything else after that."
  }
}
